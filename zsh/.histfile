EFI_STATUS EfiMain(EFI_HANDLE ImageHandle, EFI_SYSTEM_TABLE *st) {\
  (void)ImageHandle;\
\
  if (init_framebuffer(st) != EFI_SUCCESS)\
    return EFI_NOT_FOUND;\
  if (init_arena(st, 1024 * 1024 * 16) != EFI_SUCCESS)\
    return EFI_NOT_FOUND;\
  init_keyboard(st);\
\
  tui_clear();\
\
  tui_printf("%s\n", LLAMA_ASCII_LOGO);\
\
  tui_printf("\x1b[1;33mŌā┤ā»Ōā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤ā│\x1b[0m\n");\
  tui_printf("\x1b[1;33mŌā┤āŻ\x1b[0m  PureBLM v1.0 - Unikernel LLM Bootloader                   \x1b[1;33mŌā┤āŻ\x1b[0m\n");\
  tui_printf("\x1b[1;33mŌā┤āŻ\x1b[0m  Model: %-53s \x1b[1;33mŌā┤āŻ\x1b[0m\n", "Qwen2.5-0.5B-Instruct-GGUF");\
  tui_printf("\x1b[1;33mŌā┤āĘŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤üŌā┤ā╗\x1b[0m\n\n");\
\
  tui_printf("\x1b[2mType your message and press Enter. Reboot to exit.\x1b[0m\n\n");\
\
  llm_init();\
\
  char prompt_buf[256];\
  int prompt_ptr = 0;\
\
  while (1) {\
    tui_printf("\x1b[1;35m> \x1b[0m");\
    prompt_ptr = 0;\
    while (1) {\
      int k = tui_waitkey();\
      if (k == '\r') {\
        tui_printf("\n");\
        prompt_buf[prompt_ptr] = 0;\
        break;\
      } else if (k == '\b') {\
        if (prompt_ptr > 0) {\
          prompt_ptr--;\
          tui_printf("\b \b");\
        }\
      } else if (k >= 32 && k < 127 && prompt_ptr < 255) {\
        prompt_buf[prompt_ptr++] = (char)k;\
        tui_printf("%c", (char)k);\
      }\
    }\
\
    if (prompt_ptr > 0) {\
      llm_infer(prompt_buf);\
    }\
  }\
\
  return EFI_SUCCESS;\
}\
EOF
