#pragma pack(push, 1)\
struct BundleFooter {\
    uint64_t model_offset;\
    uint64_t model_size;\
    uint32_t magic;\
};\
#pragma pack(pop)\
int main(int argc, char **argv) {\
    if(argc<2) return 1;\
    FILE *f = fopen(argv[1], "rb");\
    if(f) {\
        fseek(f, -(long)sizeof(struct BundleFooter), SEEK_END);\
        struct BundleFooter footer;\
        fread(&footer, sizeof(footer), 1, f);\
        printf("Size: %zu, Magic: %x\n", sizeof(footer), footer.magic);\
        fclose(f);\
    }\
    return 0;\
}\
